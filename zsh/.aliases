# ============================================================

# Core terminal

# ============================================================

alias c='clear'
alias h='history'
alias p='pwd'
alias reload='exec zsh'
alias path='echo -e ${PATH//:/\n}'
alias now='date +"%Y-%m-%d %H:%M:%S"'
alias week='date +%V'
alias weather='curl wttr.in'

# Safer defaults

alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'

# Fast destructive remove, intentional use only

alias rd='rm -rf --'
alias rdi='rm -rfi'

# ============================================================

# Files / directories

# ============================================================

alias t='touch'
alias md='mkdir -p'
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'
alias lh='ls -lh'
alias lt='ls -lahtr'
alias tree1='tree -L 1'
alias tree2='tree -L 2'
alias tree3='tree -L 3'

alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ~='cd ~'
alias desk='cd ~/Desktop'
alias dl='cd ~/Downloads'
alias docs='cd ~/Documents'
alias gh='cd ~/github'

mkcd() {
mkdir -p "$1" && cd "$1"
}

take() {
mkdir -p "$1" && cd "$1"
}

cdf() {
cd "$(dirname "$1")"
}

ff() {
local results; results=$(find . -iname "*$1*")
[[ -z "$results" ]] && { echo "no matches for '$1'"; return 1; }
echo "$results"
}

fdc() {
local results; results=$(find . -type d -iname "*$1*")
[[ -z "$results" ]] && { echo "no matches for '$1'"; return 1; }
echo "$results"
}

bigfiles() {
find . -type f -exec du -h {} + | sort -hr | head -20
}

recent() {
find . -type f -maxdepth 2 -print0 | xargs -0 ls -lt | head -20
}

copyfile() {
pbcopy < "$1"
}

copycwd() {
pwd | pbcopy
}

# ============================================================

# Editor / shell config

# ============================================================

alias ez="${EDITOR:-vim} ~/.zshrc"
alias ea="${EDITOR:-vim} ~/.aliases"
alias el="${EDITOR:-vim} ~/.local.zsh"
alias eaws="${EDITOR:-vim} ~/.aws_helpers.zsh"
alias sz='exec zsh'
alias sa='source ~/.aliases'
alias szrc='source ~/.zshrc'

# ============================================================

# Claude Code terminal

# ============================================================

alias cla='claude'
alias clai='claude'
alias clp='claude -p'
alias clc='claude -c'
alias clr='claude -r'
alias clu='claude update'
alias cllogin='claude auth login'
alias cllogout='claude auth logout'
alias clauth='claude auth status --text'
alias clagents='claude agents'
alias cldaemon='claude daemon status'
alias clhelp='claude --help'

clfile() {
cat "$1" | claude -p "${2:-Summarize this file}"
}

clexplain() {
claude -p "Explain this project structure and identify the main entry points."
}

clreview() {
claude -p "Review this repository for bugs, security issues, maintainability problems, and missing tests."
}

cldiff() {
git diff | claude -p "Review this diff. Focus on correctness, security, and maintainability."
}

clstaged() {
git diff --staged | claude -p "Review this staged diff before commit. Focus on correctness, security, and maintainability."
}

clcommit() {
git diff --staged | claude -p "Write a concise conventional commit message for this staged diff."
}

# ============================================================

# Codex CLI (OpenAI)

# ============================================================

alias cx='codex'
alias cxe='codex exec'
alias cxl='codex login'
alias cxr='codex resume'
alias cxh='codex --help'

cxfile() {
codex exec "${2:-Summarize this file}: $(cat "$1")"
}

cxdiff() {
git diff | codex exec "Review this diff. Focus on correctness, security, and maintainability."
}

# ============================================================

# Pieces CLI

# Requires PiecesOS running (cask: pieces-os)

# ============================================================

alias pi='pieces'
alias pia='pieces ask'
alias pil='pieces list'
alias pis='pieces search'
alias pir='pieces run'
alias pio='pieces open'
alias piv='pieces version'
alias pih='pieces --help'

# ============================================================

# Git

# ============================================================

alias g='git'
alias ga='git add'
alias gaa='git add .'
alias gc='git clone'
alias gcm='git commit -m'
alias gca='git commit -v --amend'
alias gempty="git commit --allow-empty -m 'empty'"
alias gu='git restore --staged'
alias gs='git status -sb'
alias gst='git status'
alias gb='git branch'
alias gba='git branch -a'
alias gbd='git branch -d'
alias gbD='git branch -D'
alias gco='git checkout'
alias gnew='git checkout -b'
alias gsw='git switch'
alias gswc='git switch -c'
alias gf='git fetch'
alias gfa='git fetch --all --prune'
alias gr='git remote -v'
alias grau='git remote add upstream'
alias grb='git rebase'
alias grbi='git rebase -i'
alias gcp='git cherry-pick'
alias gl='git log --oneline --decorate --graph'
alias gla='git log --oneline --decorate --graph --all'
alias gll='git log --stat'
alias gllp='git log --stat -p'
alias gd='git diff'
alias gds='git diff --staged'
alias gp='git push'
alias gpf='git push --force-with-lease'
alias gpl='git pull'
alias gpr='git pull --rebase'
alias gpud='git pull upstream develop'
alias gpudr='git pull upstream develop --rebase'

gmain() {
git switch main 2>/dev/null || git switch master
}

groot() {
local root
root="$(git rev-parse --show-toplevel 2>/dev/null)" || return 1
cd "$root"
}

gcleanbranches() {
local branches; branches=$(git branch --merged | sed 's/^[*+ ]*//' | grep -vE '^(main|master|develop)$')
[[ -z "$branches" ]] && { echo "No merged branches to clean."; return 0; }
echo "$branches" | xargs -n1 git branch -d
}

# ============================================================

# AWS

# Requires ~/.aws_helpers.zsh

# ============================================================

alias awsume='. awsume'
alias awse='aws-env'
alias awsp='aws-profile'
alias awswho='aws-whoami'
alias awsclear='aws-clear-env'
alias awsprofiles='aws configure list-profiles'
alias aws-gci='aws sts get-caller-identity'
alias awsregion='aws configure get region'

# ============================================================

# Docker

# ============================================================

alias d='docker'
alias dv='docker version'
alias di='docker info'

alias dps='docker ps'
alias dpsa='docker ps -a'
alias dpsq='docker ps -q'
alias dpsaq='docker ps -aq'

alias dil='docker image ls'
alias dirm='docker image rm'
alias drmi='docker rmi'
alias dprune='docker system prune'
alias dprunea='docker system prune -a'
alias dvol='docker volume ls'
alias dnet='docker network ls'

alias db='docker build -t'
alias dex='docker exec -it'
alias dlog='docker logs -f'
alias dinsp='docker inspect'
alias dstats='docker stats'
alias dstop='docker stop'
alias drm='docker rm'
alias drmf='docker rm -f'

dsh() {
docker exec -it "$1" sh
}

dbash() {
docker exec -it "$1" bash
}

dstopall() {
local ids; ids=$(docker ps -q)
[[ -z "$ids" ]] && { echo "No running containers."; return 0; }
docker stop $ids
}

drmall() {
local ids; ids=$(docker ps -aq)
[[ -z "$ids" ]] && { echo "No containers."; return 0; }
docker rm -f $ids
}

drmimages() {
local ids; ids=$(docker images -q)
[[ -z "$ids" ]] && { echo "No images."; return 0; }
docker rmi -f $ids
}

# Docker Compose v2

alias dc='docker compose'
alias dcu='docker compose up'
alias dcud='docker compose up -d'
alias dcd='docker compose down'
alias dcr='docker compose restart'
alias dcl='docker compose logs -f'
alias dcb='docker compose build'
alias dcp='docker compose ps'
alias dce='docker compose exec'
alias dcrun='docker compose run --rm'

# ============================================================

# Kubernetes

# ============================================================

alias kube='kubectl'
alias kubectx='kubectl config current-context'
alias kubectxs='kubectl config get-contexts'
alias kubeuse='kubectl config use-context'
alias kubens='kubectl config set-context --current --namespace'
alias kubenss='kubectl get namespaces'
alias kubep='kubectl get pods'
alias kubeap='kubectl get pods -A'
alias kubes='kubectl get svc'
alias kubeas='kubectl get svc -A'
alias kubed='kubectl get deploy'
alias kubead='kubectl get deploy -A'
alias kuben='kubectl get nodes'
alias kubei='kubectl get ingress'
alias kubeai='kubectl get ingress -A'
alias kubecm='kubectl get configmap'
alias kubesec='kubectl get secret'
alias kubecj='kubectl get cronjob'
alias kubej='kubectl get job'
alias kubeall='kubectl get all'
alias kubealla='kubectl get all -A'
alias kubedp='kubectl describe pod'
alias kubedd='kubectl describe deploy'
alias kubeds='kubectl describe svc'
alias kubedn='kubectl describe node'
alias kubedi='kubectl describe ingress'
alias kubedsec='kubectl describe secret'
alias kubel='kubectl logs'
alias kubelf='kubectl logs -f'
alias kubelprev='kubectl logs --previous'
alias kubex='kubectl exec -it'
alias kubeaf='kubectl apply -f'
alias kubedf='kubectl delete -f'
alias kubedel='kubectl delete'
alias kubee='kubectl edit'
alias kuberr='kubectl rollout restart'
alias kubers='kubectl rollout status'
alias kuberh='kubectl rollout history'
alias kuberu='kubectl rollout undo'
alias kubepf='kubectl port-forward'
alias kubetop='kubectl top pod'
alias kubetopn='kubectl top node'
alias kubeevents='kubectl get events --sort-by=.lastTimestamp'
alias kubeeventsa='kubectl get events -A --sort-by=.lastTimestamp'
alias kubepw='kubectl get pods -o wide'
alias kubeaw='kubectl get pods -A -o wide'
alias kubepy='kubectl get pod -o yaml'
alias kubedy='kubectl get deploy -o yaml'
alias kubesy='kubectl get svc -o yaml'

kubesh() {
kubectl exec -it "$1" -- sh
}

kubebash() {
kubectl exec -it "$1" -- bash
}

klogs() {
kubectl logs -f "$1"
}

kpodsbyimage() {
kubectl get pods -A -o jsonpath='{range .items[*]}{.metadata.namespace}{" "}{.metadata.name}{" "}{range .spec.containers[*]}{.image}{" "}{end}{"\n"}{end}'
}

kubelogs() {
kubectl logs -f "$1"
}

kubepodsbyimage() {
kubectl get pods -A -o jsonpath='{range .items[]}{.metadata.namespace}{" "}{.metadata.name}{" "}{range .spec.containers[]}{.image}{" "}{end}{"\n"}{end}'
}

kubewatchpods() {
watch kubectl get pods
}

kubewatchallpods() {
watch kubectl get pods -A
}

kubefindpod() {
kubectl get pods -A | grep -i "$1" || { echo "no pods matching '$1'"; return 1; }
}

kubefindsvc() {
kubectl get svc -A | grep -i "$1" || { echo "no services matching '$1'"; return 1; }
}

kubefinddeploy() {
kubectl get deploy -A | grep -i "$1" || { echo "no deployments matching '$1'"; return 1; }
}

